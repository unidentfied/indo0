# ============================================================
# Sindio — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sindio
DB_USER=sindio_user
DB_PASSWORD=change_me_in_production
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Qdrant (Vector Store) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sindio_embeddings

# --- Elasticsearch / OpenSearch for hybrid text search ---
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_INDEX_ALERTS=sindio_alerts
# Set to "opensearch" to use the OpenSearch client instead of elasticsearch-py
ES_CLIENT_TYPE=elasticsearch

# --- MinIO (S3-compatible satellite imagery storage) ---
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_IMAGERY_BUCKET=sindio-satellite-imagery
MINIO_GIS_BUCKET=sindio-gis-rasters

# --- PGAdmin (DB inspection console) ---
PGADMIN_EMAIL=admin@sindio.urban
PGADMIN_PASSWORD=sindio_admin

# --- LocalStack (Mock AWS SQS/SNS for mobility streams) ---
AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_SQS_MOBILITY_QUEUE=sindio-mobility-stream
LOCALSTACK_SQS_TELEMETRY_QUEUE=sindio-utility-telemetry
LOCALSTACK_SNS_ALERTS_TOPIC=sindio-system-alerts

# --- Service Ports ---
API_PORT=8080
CORE_PORT=8081
STREAMING_PORT=8082
FRONTEND_PORT=3000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Model Paths ---
MODEL_PATH=../../models/trained
EMBEDDINGS_PATH=../../models/embeddings
VECTOR_STORE_PATH=../../data/vector_store

# --- External APIs ---
OPENAI_API_KEY=sk-placeholder
MAPBOX_ACCESS_TOKEN=pk.placeholder
HUGGINGFACE_HUB_TOKEN=hf_placeholder
SERPAPI_API_KEY=your-serpapi-key

# --- Auth ---
JWT_SECRET=change_this_to_a_random_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Logging ---
LOG_LEVEL=info
RUST_LOG=sindio_streaming=info,tower_http=debug

# --- Development ---
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/raw
# Set to 1 to skip WorldPop raster download (297 MB) and use hardcoded
# high-density Nairobi coordinates as fallback. Speeds up frontend development.
# SINDIO_SKIP_RASTER=1
