# Sindio Frontend Environment
# Copy this file to .env.local for local development
# Railway/Netlify will inject production values automatically

# Backend API base URL (no trailing slash)
# Leave empty in dev to use Vite proxy; set to deployed backend URL in production
# Example: https://sindio-api.up.railway.app
VITE_API_BASE_URL=

# Optional: override API proxy target for local dev
# VITE_API_URL=http://localhost:8080
