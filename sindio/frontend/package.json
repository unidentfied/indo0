{
  "name": "sindio-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "postbuild": "node -e \"const fs=require('fs'); const p='dist/sw.js'; if(fs.existsSync(p)){let s=fs.readFileSync(p,'utf8'); s=s.replace(/BUILD_HASH_PLACEHOLDER/g,Date.now().toString()); fs.writeFileSync(p,s); console.log('SW cache busted');}\"",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "lint": "node ./node_modules/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": "^9.3.2",
    "@deck.gl/layers": "^9.3.2",
    "@deck.gl/react": "^9.3.2",
    "lucide-react": "^0.303.0",
    "maplibre-gl": "^5.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-map-gl": "^8.1.1",
    "react-router-dom": "^6.21.0",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/geojson": "^7946.0.14",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "jsdom": "^23.2.0",
    "playwright": "^1.49.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.8",
    "vitest": "^1.6.1"
  }
}
